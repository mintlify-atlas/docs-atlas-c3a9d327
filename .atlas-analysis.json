  "keyFeatures": [
    "Program creation and management",
    "Student and teacher registration workflows",
    "Class scheduling and lottery system",
    "Financial aid processing",
    "Payment integration (Stripe, CyberSource)",
    "Resource management (classrooms, materials)",
    "Onsite check-in and attendance tracking",
    "Custom forms and surveys",
    "Email and SMS communication (Twilio)",
    "Customizable themes and branding",
    "Multi-role permissions system",
    "Admin dashboard and reporting"
  ],
  "publicApiSurface": [
    "/manage/newprogram - Create new program",
    "/learn/<program>/<instance>/ - Student registration portal",
    "/teach/<program>/<instance>/ - Teacher registration portal",
    "/manage/<program>/<instance>/ - Admin management interface",
    "/onsite/<program>/<instance>/ - Onsite check-in interface",
    "/volunteer/<program>/<instance>/ - Volunteer signup",
    "/admin/ - Django admin interface",
    "/themes/ - Theme customization",
    "/customforms/ - Custom form builder",
    "Program model - Core program management",
    "ClassSubject model - Class definition",
    "ClassSection model - Class section/timeblock",
    "ESPUser model - Extended user model",
    "StudentRegistration model - Student class registration",
    "ProgramModule system - Extensible module framework"
  ]
